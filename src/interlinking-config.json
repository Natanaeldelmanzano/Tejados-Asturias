      "opcional":    ["urgencias-tejados-{ciudad}", "impermeabilizacion-cubiertas"]
    },
    "urgencias": {
      "obligatorio": ["reparacion-goteras-{ciudad}", "urgencias-goteras-24h", "tejados-{ciudad}"],
      "recomendado": ["presupuesto-tejados-{ciudad}", "reparacion-tejados-asturias"],
      "opcional":    ["impermeabilizacion-cubiertas", "canalones-asturias"]
    },
    "trabajos": {
      "obligatorio": ["tejados-{ciudad}", "presupuesto-tejados-{ciudad}"],
      "recomendado": ["reforma-tejados-oviedo", "reparacion-tejados-asturias", "precios-reforma-tejado-{ciudad}"],
      "opcional":    ["impermeabilizacion-cubiertas", "tejados-pizarra-teja", "canalones-asturias"]
    },
    "precios": {
      "obligatorio": ["presupuesto-tejados-{ciudad}", "tejados-{ciudad}"],
      "recomendado": ["reforma-tejados-oviedo", "tejados-pizarra-teja", "aislamiento"],
      "opcional":    ["impermeabilizacion-cubiertas", "panel-sandwich-asturias", "trabajos-realizados-{ciudad}"]
    }
  },

