  "interlinking_matrix": {
    "descripcion": "Qué páginas debe enlazar cada tipo",
    "goteras": {
      "obligatorio": ["urgencias-{ciudad}", "presupuesto-tejados-{ciudad}", "tejados-{ciudad}"],
